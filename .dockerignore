# Local dev / build artefacts not needed in the image.
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Source control & editor
.git/
.gitignore
.github/
.vscode/
.idea/

# Local env / secrets — must NEVER ship in the image.
env/
.env
.env.*
*.local

# Build outputs / packages
dist/
build/
*.egg-info/

# Docker meta
Dockerfile
.dockerignore

# Docs / scratch
docs/
images/
*.md

# Agent 365 generated state (regenerated by the CLI)
a365.generated.config.json
a365.generated.config.*.json
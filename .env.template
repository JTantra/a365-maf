# .env.template — reference of every variable the agent reads at runtime.
# Copy what you need into a local `.env` (or set via your hosting tool's env
# var mechanism) and fill in the values.
#
# Two deployment modes are covered:
#
#   * LOCAL DEV / PLAYGROUND — use `env/.env.playground` + `env/.env.playground.user`
#     (Microsoft 365 Agents Toolkit conventions, SECRET_* prefixing). Skip
#     this file unless you're hand-rolling a launch.
#
#   * PRODUCTION (Azure Container Apps / Web App / AKS) — see
#     `env/.env.production.example`. Set values via the platform's env-var
#     / secret mechanism (`az containerapp update --set-env-vars` /
#     `--secrets`), NOT by shipping a `.env` file into the container image.
#
# Use managed identity in production. Leave AZURE_OPENAI_API_KEY *unset* and
# `agent.py` will use DefaultAzureCredential, which resolves to the workload
# MI on Azure and `az login` locally.

# This is a demo .env file for hand-rolled local launches. The Microsoft 365
# Agents Playground uses env/.env.playground{,.user} instead.

# Authentication Handler Configuration
# Set to "AGENTIC" for production agentic auth, or leave empty for no auth handler
AUTH_HANDLER_NAME=

# Logging
LOG_LEVEL=INFO

# Observability Configuration
OBSERVABILITY_SERVICE_NAME=agent-framework-sample
OBSERVABILITY_SERVICE_NAMESPACE=agent-framework.samples

BEARER_TOKEN=

USE_AGENTIC_AUTH=true

# Agent 365 Agentic Authentication Configuration
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__SCOPES=

AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__TYPE=AgenticUserAuthorization
# Prod Agent 365 agentic scope (same value as env/.env.playground -> agentic_scopes).
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__SCOPES=ea9ffc3e-8a23-4a7d-836d-234d7c7565c1/.default
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__ALTERNATEBLUEPRINTCONNECTIONNAME=SERVICE_CONNECTION

CONNECTIONSMAP_0_SERVICEURL=*
CONNECTIONSMAP_0_CONNECTION=SERVICE_CONNECTION

# Optional: Server Configuration
PORT=3978

# Azure OpenAI Configuration
# In production, leave AZURE_OPENAI_API_KEY UNSET so the agent uses
# DefaultAzureCredential. On Azure Container Apps / Web App this picks up the
# **system-assigned managed identity** automatically. Grant that MI the
# "Cognitive Services OpenAI User" role on the Foundry / Azure OpenAI resource.
# Locally it falls through to `az login`.
#
AZURE_OPENAI_ENDPOINT=https://terenceaifoundry-resource.openai.azure.com/openai/v1
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_API_VERSION=2024-10-21

# Required for observability SDK
ENABLE_OBSERVABILITY=true
ENABLE_A365_OBSERVABILITY_EXPORTER=false
PYTHON_ENVIRONMENT=development

# Enable otel logs on AgentFramework SDK. Required for auto instrumentation
ENABLE_OTEL=true
ENABLE_SENSITIVE_DATA=true

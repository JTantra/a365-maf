{
    "version": "2.0.0",
    "tasks": [
        {
            // Check all required prerequisites.
            // Uses a shell task instead of a Toolkit-specific task provider so it works reliably in Dev Containers.
            "label": "Validate prerequisites (Microsoft 365 Agents Playground)",
            "type": "shell",
            "command": "node",
            "args": [
                "${workspaceFolder}/.vscode/scripts/validate-playground-prerequisites.mjs"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Refresh bearer token (Microsoft 365 Agents Playground)",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.vscode/scripts/refresh-bearer-token.ps1"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            // Build project.
            // Runs the Microsoft 365 Agents Toolkit deploy lifecycle for the Playground environment.
            "label": "Deploy (Microsoft 365 Agents Playground)",
            "dependsOn": [
                "Validate prerequisites (Microsoft 365 Agents Playground)",
                "Refresh bearer token (Microsoft 365 Agents Playground)"
            ],
            "dependsOrder": "sequence",
            "type": "shell",
            "command": "atk",
            "args": [
                "deploy",
                "--env",
                "playground",
                "--config-file-path",
                "${workspaceFolder}/m365agents.playground.yml",
                "--interactive",
                "false"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
    ]
}

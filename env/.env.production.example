# .env.production.example
#
# Reference for the variables to set when deploying the agent to Azure
# Container Apps / Azure Web App / AKS. DO NOT commit a populated copy;
# DO NOT bake real values into the Docker image. Use your platform's
# native env var / secret mechanism instead:
#
#   az containerapp update -n <app> -g <rg> \
#     --set-env-vars VAR1=value1 VAR2=value2 \
#     --secrets api-key=secretvalue \
#     --set-env-vars AZURE_OPENAI_API_KEY=secretref:api-key
#
#   az webapp config appsettings set -n <app> -g <rg> --settings VAR=value
#
# What the agent reads at runtime is documented inline below.


# ===========================================================================
# Networking (Docker / Container Apps only)
# ===========================================================================
# Set both in the container so aiohttp binds the container-network interface
# instead of localhost-only. The provided Dockerfile sets these for you;
# only override if you need a different port.
HOST=0.0.0.0
PORT=3978


# ===========================================================================
# Azure OpenAI / Foundry — use system-assigned managed identity (no secrets)
# ===========================================================================
# Leave AZURE_OPENAI_API_KEY UNSET. agent.py falls back to
# DefaultAzureCredential, which on Container Apps / App Service / AKS
# resolves to the workload's **system-assigned managed identity**
# automatically. Grant that MI principal the "Cognitive Services OpenAI
# User" role on the Foundry / Azure OpenAI account.
#
#   MI_PRINCIPAL_ID=$(az containerapp show -n <app> -g <rg> \
#     --query identity.principalId -o tsv)
#   az role assignment create --assignee "$MI_PRINCIPAL_ID" \
#     --role "Cognitive Services OpenAI User" \
#     --scope "/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<account>"
#
# Defaults below match infra/main.bicep (terenceaifoundry-resource + gpt-5.4).
# Override per environment as needed.
AZURE_OPENAI_ENDPOINT=https://terenceaifoundry-resource.openai.azure.com/openai/v1
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_API_VERSION=2024-10-21


# ===========================================================================
# Agent 365 blueprint auth (server identity)
# ===========================================================================
# These let the host validate inbound JWTs from the M365 messaging fabric
# and acquire its own tokens when calling Microsoft Graph as the agent.
# Grab CLIENT_ID / TENANT_ID from `a365.generated.config.json` (or the
# blueprint app in Entra). CLIENT_SECRET is the blueprint's client secret
# — print it with `a365 setup blueprint --agent-name <name> --show-secret`
# and store as a Container Apps SECRET, not as a plain env var.
CLIENT_ID=<blueprint-app-id>
TENANT_ID=<your-tenant-id>
# CLIENT_SECRET=secretref:blueprint-client-secret


# ===========================================================================
# Agent 365 connections (Microsoft Agents SDK)
# ===========================================================================
# Same three values as above, exposed under the SDK's hierarchical naming
# convention. The hosting SDK reads these to bootstrap the service connection.
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=<blueprint-app-id>
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=<your-tenant-id>
# CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=secretref:blueprint-client-secret
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__SCOPES=https://graph.microsoft.com/.default

CONNECTIONSMAP_0_SERVICEURL=*
CONNECTIONSMAP_0_CONNECTION=SERVICE_CONNECTION


# ===========================================================================
# Authentication mode
# ===========================================================================
# AGENTIC — agent acts as its own identity (Agent 365 production path).
# Leave empty to run without an auth handler (dev / playground only).
AUTH_HANDLER_NAME=AGENTIC
USE_AGENTIC_AUTH=true

AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__TYPE=AgenticUserAuthorization
# Prod Agent 365 agentic scope (same value as env/.env.playground -> agentic_scopes).
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__SCOPES=ea9ffc3e-8a23-4a7d-836d-234d7c7565c1/.default
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__AGENTIC__SETTINGS__ALTERNATEBLUEPRINTCONNECTIONNAME=SERVICE_CONNECTION


# ===========================================================================
# Observability
# ===========================================================================
# A365 observability sends traces / metrics / logs to the Agent 365 backend
# using the agentic token cache. Azure Monitor export is opt-in via
# ENABLE_A365_OBSERVABILITY_EXPORTER=true plus an Application Insights conn
# string in APPLICATIONINSIGHTS_CONNECTION_STRING.
ENABLE_OBSERVABILITY=true
ENABLE_A365_OBSERVABILITY_EXPORTER=true
ENABLE_OTEL=true
ENABLE_SENSITIVE_DATA=false
PYTHON_ENVIRONMENT=production
LOG_LEVEL=INFO
OBSERVABILITY_SERVICE_NAME=agent-framework-sample
OBSERVABILITY_SERVICE_NAMESPACE=agent-framework.samples

# Optional: Azure Monitor / Application Insights for parallel export.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
